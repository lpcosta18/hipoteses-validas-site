<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contactos - Hipóteses Válidas</title>
    <meta name="description" content="Contacte a Hipóteses Válidas em Torres Vedras para serviços de contabilidade, fiscalidade e apoio à gestão.">
    <link rel="icon" type="image/png" href="assets/logo/logo-hv-favicon-optimized.png">
    <link rel="stylesheet" href="style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    {% include "header.njk" %}

    <main id="main-content" tabindex="-1">
        <section class="page-header">
            <div class="container">
                <h1>Contactos</h1>
            </div>
        </section>

        <section class="contact-section">
            <div class="container contact-container">
                <div class="contact-info">
                    <div class="info-card">
                        <h3>Informação prática</h3>
                        
                        <div class="info-item">
                            <img src="assets/icons/phone-ouro.svg" alt="Telefone" class="info-icon">
                            <div>
                                <strong>Telefone</strong>
                                <p><a href="tel:968481817">968 481 817</a></p>
                            </div>
                        </div>

                        <div class="info-item">
                            <img src="assets/icons/mail-ouro.svg" alt="Email" class="info-icon">
                            <div>
                                <strong>Email</strong>
                                <p><a href="mailto:geral@hipoteses-validas.pt">geral@hipoteses-validas.pt</a></p>
                            </div>
                        </div>

                        <div class="info-item">
                            <img src="assets/icons/clock-ouro.svg" alt="Horário" class="info-icon">
                            <div>
                                <strong>Horário</strong>
                                <p>Segunda a Sexta<br>9h00-13h00 e 14h00-18h00</p>
                            </div>
                        </div>

                        <div class="info-item">
                            <img src="assets/icons/location-ouro.svg" alt="Morada" class="info-icon">
                            <div>
                                <strong>Morada</strong>
                                <p>Rua Joaquim Maria Simões, 1<br>2560-281 Torres Vedras</p>
                            </div>
                        </div>
						<div class="map-container">
							<iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3081.123456789!2d-9.258456!3d39.123456!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd186e1e2d5b2b7f%3A0x123456789abcdef!2sRua%20Joaquim%20Maria%20Sim%C3%B5es%2C%201%2C%202560-281%20Torres%20Vedras!5e0!3m2!1spt-PT!2spt!4v1234567890" width="100%" height="300" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
						</div>

                    </div>
                    
                </div>
                
                <div class="contact-form">
                    <h3>Envie-nos uma mensagem</h3>
                    
                    <form id="contactForm" action="#" method="post" novalidate aria-label="Formulário de contacto">
                        <div class="form-group">
                            <label for="nome">Nome completo *</label>
                            <input type="text" id="nome" name="nome" required aria-required="true" aria-describedby="nome-help">
                            <small id="nome-help" class="form-help">Introduza o seu nome completo</small>
                        </div>

                        <div class="form-group">
                            <label for="email">Email *</label>
                            <input type="email" id="email" name="email" required aria-required="true" aria-describedby="email-help">
                            <small id="email-help" class="form-help">Introduza um endereço de email válido</small>
                        </div>

                        <div class="form-group">
                            <label for="telemovel">Telemóvel</label>
                            <input type="tel" id="telemovel" name="telemovel" aria-describedby="telemovel-help">
                            <small id="telemovel-help" class="form-help">Opcional - para contacto mais rápido</small>
                        </div>

                        <div class="form-group">
                            <label for="assunto">Assunto</label>
                            <select id="assunto" name="assunto" aria-describedby="assunto-help">
                                <option value="">Selecione um assunto</option>
                                <option value="contabilidade">Contabilidade</option>
                                <option value="fiscalidade">Fiscalidade</option>
                                <option value="recursos-humanos">Recursos Humanos</option>
                                <option value="seguros">Mediação de Seguros</option>
                                <option value="outro">Outro</option>
                            </select>
                            <small id="assunto-help" class="form-help">Selecione o assunto da sua mensagem</small>
                        </div>
                        
                        <div class="form-group">
                            <label for="mensagem">Mensagem *</label>
                            <textarea id="mensagem" name="mensagem" rows="5" required aria-required="true" aria-describedby="mensagem-help"></textarea>
                            <small id="mensagem-help" class="form-help">Descreva o motivo do seu contacto</small>
                        </div>

                        <button type="submit" class="btn btn-primary btn-submit" aria-label="Enviar mensagem do formulário">Enviar mensagem</button>
                        <p class="form-note">* Campos obrigatórios</p>
                    </form>
                    
                    <div id="form-success" class="form-message form-message--success" style="display: none;" role="alert" aria-live="polite" aria-atomic="true">
                        ✅ Mensagem enviada com sucesso! Entraremos em contacto brevemente.
                    </div>
                    <div id="form-error" class="form-message form-message--error" style="display: none;" role="alert" aria-live="assertive" aria-atomic="true">
                        ❌ Ocorreu um erro ao enviar a mensagem. Por favor, tente novamente.
                    </div>
                    <div id="form-loading" class="form-message form-message--info" style="display: none;" role="alert" aria-live="polite" aria-atomic="true">
                        ⏳ A enviar a sua mensagem...
                    </div>
                </div>
            </div>
        </section>
    </main>

    {% include "footer.njk" %}

    <script src="header.js"></script>
    <script src="script.js"></script>
</body>
</html>
